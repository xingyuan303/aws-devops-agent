    "@aws-sdk/client-resource-groups-tagging-api": "^3.1057.0",
    "@aws-sdk/client-secrets-manager": "^3.1053.0",
    "@aws-sdk/client-sfn": "^3.1053.0",
    "@aws-sdk/client-ssm": "^3.1046.0",
    "@aws-sdk/lib-dynamodb": "^3.1046.0",
    "aws-cdk-lib": "^2.254.0",
    "constructs": "^10.6.0",
    "source-map-support": "^0.5.21"
  },
  "devDependencies": {
