  "description": "CloudWatch Alarm Auto RCA - Automated root cause analysis with Feishu notifications",
  "main": "dist/bin/app.js",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest --runInBand",
    "test:unit": "jest --testPathPattern=test/unit",
    "test:property": "jest --testPathPattern=test/property",
    "test:integration": "jest --testPathPattern=test/integration",
    "cdk": "cdk",
    "synth": "cdk synth",
    "deploy": "cdk deploy",
    "lint": "tsc --noEmit"
